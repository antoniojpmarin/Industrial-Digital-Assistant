      ],
      "id": "bec69d03-5c4c-42c6-a3f1-7ea2fe4b53ed",
      "name": "HTTP Request Gráfica"
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst fechas = [];\nconst niveles = [];\n\nfor (const fila of allItems) {\n  fechas.push(fila.json.fecha);\n  niveles.push(fila.json.nivel);\n}\n\nconst chatId = allItems[0]?.json.chatId ?? null;\n\nreturn [\n  {\n    json: {\n      fechas,\n      niveles,\n      chatId\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1744,
        -32
      ],
      "id": "d45e1fc8-8350-4d3b-8b43-79adf9599878",
