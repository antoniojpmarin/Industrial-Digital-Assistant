      "parameters": {
        "jsCode": "return [\n  {\n    json: {},\n    binary: {\n      data: {\n        data: Buffer.from($json.imagen, 'base64'),\n        mimeType: 'image/png',\n        fileName: 'grafica.png'\n      }\n    }\n  }\n];\n"
      },
