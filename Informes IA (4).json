        "query": "SELECT nivel, fecha, estado, sp, alarma, caudal_entrada, caudal_salida\nFROM nivel_tanque\nWHERE fecha >= (NOW() AT TIME ZONE 'Europe/Madrid')::timestamp - INTERVAL '15 minutes'\nORDER BY fecha ASC;\n",
