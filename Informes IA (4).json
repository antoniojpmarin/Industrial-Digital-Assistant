    {
      "parameters": {
        "jsCode": "const datos = $input.all().map(i => ({\n  nivel: parseFloat(i.json.nivel ?? '0'),\n  fecha: i.json.fecha ?? '',\n  estado: i.json.estado ?? 'OFF',\n  sp: i.json.sp !== null && i.json.sp !== undefined ? parseFloat(i.json.sp) : null,\n  alarma: i.json.alarma ?? false,\n  caudal_entrada: i.json.caudal_entrada ?? 0,\n  caudal_salida: i.json.caudal_salida ?? 0\n}));\n\nconst niveles = datos.map(d => d.nivel);\nconst nivelMin = parseFloat(Math.min(...niveles).toFixed(2));\nconst nivelMax = parseFloat(Math.max(...niveles).toFixed(2));\nconst nivelProm = parseFloat((niveles.reduce((a,b) => a+b, 0) / niveles.length).toFixed(2));\nconst alarmasAlto = datos.filter(d => d.alarma === 'nivel alto').length;\nconst alarmasBajo = datos.filter(d => d.alarma === 'nivel bajo').length;\nconst alarmasOn = alarmasAlto + alarmasBajo;\nconst spReferencia = datos.find(d => d.sp !== null)?.sp ?? null;\nconst spValido = spReferencia !== null;\n\nconst prompt = `Eres un ingeniero de procesos industriales. Redacta un informe técnico BREVE (máximo 8 líneas) en español sobre el comportamiento general del tanque durante los últimos 15 minutos.\n\nDATOS DEL TANQUE (${datos.length} registros):\n- Nivel mínimo: ${nivelMin}%\n- Nivel máximo: ${nivelMax}%\n- Nivel promedio: ${nivelProm}%\n- Setpoint: ${spValido ? spReferencia + \"%\" : \"Modo simulación (SP variable)\"}\n- Alarmas activas: ${alarmasOn} (nivel alto: ${alarmasAlto}, nivel bajo: ${alarmasBajo})\n- Rango seguro: 30% – 70%\n\nSecciones:\n1. Resumen del período\n2. Incidencias destacadas\n3. Recomendaciones\n\nSé conciso. No especules ni añadas información que no esté en los datos.`;\n\nreturn [{ json: { prompt } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1744,
        224
      ],
      "id": "d5f0c33b-d1b3-492b-9f10-6d5d6085273f",
      "name": "Prompt para Ollama"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://python-grafica:5000/grafica",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
