      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst fechas = [];\nconst niveles = [];\n\nfor (const fila of allItems) {\n  fechas.push(fila.json.fecha);\n  niveles.push(fila.json.nivel);\n}\n\nconst chatId = allItems[0]?.json.chatId ?? null;\nconst minutos = allItems[0]?.json.minutos ?? 15;\n\nreturn [{ json: { fechas, niveles, chatId, minutos } }];"
      },
