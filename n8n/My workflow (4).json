        "jsCode": "const body = $input.first().json.body;\n\nconst fechaDB = new Date()\n  .toLocaleString(\"sv-SE\", { timeZone: \"Europe/Madrid\", hour12: false })\n  .replace(\" \", \"T\");\n\nreturn [{\n  json: {\n    fecha: fechaDB,\n    tipo: body.tipo || \"desconocido\",\n    descripcion: body.descripcion || \"\",\n    nivel_ultimo: body.nivel || 0\n  }\n}];"
