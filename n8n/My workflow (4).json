    {
      "parameters": {
        "jsCode": "const ultimaRegistrada = $input.first()?.json?.alarma || 'ninguna';\n\n// Los datos vienen del webhook de alarma, no del de datos\nconst alarmaEntrante = $('Webhook Receive Alarm').first().json.body.alarma;\nconst fecha = $('Webhook Receive Alarm').first().json.body.fecha;\n\n// Considerar \"recuperada\" y \"ninguna\" como el mismo estado (normal)\nconst estabaEnNormal = ultimaRegistrada === 'ninguna' || ultimaRegistrada === 'recuperada';\nconst entraEnNormal = alarmaEntrante === 'ninguna';\n\n// Si ambos son estado normal → no hacer nada\nif (estabaEnNormal && entraEnNormal) return [];\n\n// Si no ha cambiado la alarma activa → no hacer nada\nif (ultimaRegistrada === alarmaEntrante) return [];\n\n// Si vuelve a normal → recuperada\nif (entraEnNormal) {\n  return [{ json: { alarma: 'recuperada', fecha } }];\n}\n\n// Nueva alarma activa\nreturn [{ json: { alarma: alarmaEntrante, fecha } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1872,
        -400
      ],
